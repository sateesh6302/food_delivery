{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.51.171.228:4000/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "http://13.51.171.228:4000/images/:path*"
    },
    {
      "source": "/((?!api|images|assets|static|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
