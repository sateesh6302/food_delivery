{
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://13.51.171.228:4000/api/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "http://13.51.171.228:4000/images/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
